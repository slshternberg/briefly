# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/briefly?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Public URL of the app (no trailing slash)
AUTH_URL="https://your-domain.com"

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key used to encrypt stored OAuth tokens (Google refresh tokens)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
# Optional — defaults to gemini-2.5-flash-preview-05-20
GEMINI_MODEL="gemini-2.5-flash-preview-05-20"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for verification, password reset, and invitation emails.
# All SMTP_* fields are validated at startup — see src/lib/env.ts.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"    # "true" for port 465 (SSL), "false" for 587 (STARTTLS)
SMTP_USER="your-sender@gmail.com"
SMTP_PASS="your-app-password"

# ─── Google OAuth (for Gmail send feature) ────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── File Storage ─────────────────────────────────────────────────────────────
# "local" stores files in ./uploads/ on the server (default)
# "s3"    stores files in an S3-compatible bucket
STORAGE_TYPE="local"

# S3 settings — required only when STORAGE_TYPE=s3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="your-bucket-name"

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
# Required when subscription billing is enabled
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from your Stripe dashboard
STRIPE_PRO_PRICE_ID="price_..."
