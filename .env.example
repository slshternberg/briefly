# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/briefly?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# REQUIRED: at least 32 characters. Build AND runtime both fail on shorter values
# (see src/lib/env.ts). Generate a fresh one:
#   Linux/macOS:  openssl rand -base64 32
#   Any platform: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotating this secret invalidates every existing session (users must log in
# again) — see docs/deploy/auth-secret-rotation.md.
AUTH_SECRET="generate-with-openssl-rand-base64-32-or-longer"
# Public URL of the app (no trailing slash)
AUTH_URL="https://your-domain.com"

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key used to encrypt stored OAuth tokens (Google refresh tokens)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
# Optional — defaults to gemini-2.5-flash (stable). The preview model
# "gemini-2.5-flash-preview-05-20" was removed upstream in 2026-04 — do not
# set it here.
GEMINI_MODEL="gemini-2.5-flash"
# Optional — model used when GEMINI_MODEL returns 503/UNAVAILABLE.
# Default: gemini-2.5-flash-lite (cheaper, smaller).
# To prefer reliability over cost (analysis succeeds even when flash is
# overloaded), set this to gemini-2.5-pro.
GEMINI_FALLBACK_MODEL="gemini-2.5-flash-lite"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for verification, password reset, and invitation emails.
# All SMTP_* fields are validated at startup — see src/lib/env.ts.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"    # "true" for port 465 (SSL), "false" for 587 (STARTTLS)
SMTP_USER="your-sender@gmail.com"
SMTP_PASS="your-app-password"

# ─── Google OAuth (for Gmail send feature) ────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── File Storage ─────────────────────────────────────────────────────────────
# "local" stores files in ./uploads/ on the server (default)
# "s3"    stores files in an S3-compatible bucket
STORAGE_TYPE="local"

# S3 settings — required only when STORAGE_TYPE=s3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="your-bucket-name"

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
# Required when subscription billing is enabled
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from your Stripe dashboard
STRIPE_PRO_PRICE_ID="price_..."
